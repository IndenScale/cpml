#!/usr/bin/env bash
set -euo pipefail

echo "==> cargo fmt --check"
cargo fmt --check

echo "==> cargo clippy --all-targets -- -D warnings"
cargo clippy --all-targets -- -D warnings

echo "==> cargo test"
cargo test

echo "==> cargo build (-D warnings)"
RUSTFLAGS="-D warnings" cargo build

echo "==> cargo deny check"
cargo deny check

echo "All checks passed ✓"
